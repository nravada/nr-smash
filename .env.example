# nr-smash Environment Variables
# Copy this file to .env and fill in your values

# Slack API Configuration
# Required for bug collector when using --slack-channels
# Get a bot token from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Jira API Configuration
# Required for bug collector when using --jira-projects
JIRA_BASE_URL=https://new-relic.atlassian.net
JIRA_EMAIL=your-email@newrelic.com
JIRA_API_TOKEN=your-jira-api-token-here

# Anthropic API Configuration
# Required for bug classifier (used by collector for Slack messages)
# Get an API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
